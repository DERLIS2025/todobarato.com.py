// Prisma schema for Todobarato.com.py admin database

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProductStatus {
  ACTIVE
  DRAFT
  OUT_OF_STOCK
}

enum BannerStatus {
  ACTIVE
  INACTIVE
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  icon        String?
  description String?
  image       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)

  products    Product[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique
  brand           String?
  sku             String?
  description     String?
  longDescription String?

  price           Int
  oldPrice        Int?
  stock           Int           @default(0)

  image           String?
  gallery         String[]      @default([])
  badges          String[]      @default([])
  variants        String[]      @default([])
  colors          String[]      @default([])

  rating          Float         @default(5)
  reviews         Int           @default(0)
  sold            Int           @default(0)

  isNew           Boolean       @default(false)
  featured        Boolean       @default(false)
  status          ProductStatus @default(ACTIVE)

  seoTitle        String?
  seoDescription  String?

  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Banner {
  id          String       @id @default(cuid())
  title       String
  text        String?
  href        String?
  image       String?
  mobileImage String?
  ctaLabel    String?
  location    String       @default("home")
  color       String?
  order       Int          @default(0)
  status      BannerStatus @default(ACTIVE)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model HomeSection {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  subtitle    String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("ADMIN")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  phone     String?  @unique
  document  String?
  city      String?
  address   String?
  notes     String?
  isActive  Boolean  @default(true)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id             String      @id @default(cuid())
  orderNumber    String      @unique
  customerId     String?
  customer       Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  status         String      @default("NEW")
  paymentMethod  String?
  deliveryMethod String?
  subtotal       Int         @default(0)
  shippingCost   Int         @default(0)
  total          Int         @default(0)
  notes          String?
  items          OrderItem[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  productName String
  sku         String?
  quantity    Int      @default(1)
  unitPrice   Int      @default(0)
  total       Int      @default(0)
  createdAt   DateTime @default(now())
}

